---
import { Icon } from "astro-icon/components"
import McMasterFooterLogo from "@/icons/mcmaster-footer-logo-v2.svg"

const links = [
  {
    title: "Contact",
    link: "https://www.mcmaster.ca/opr/html/opr/contact_us/main/contact_us.html",
  },
  {
    title: "Terms & Conditions",
    link: "https://www.mcmaster.ca/opr/html/footer/main/terms_of_use.html",
  },
  {
    title: "Privacy Policy",
    link: "https://www.mcmaster.ca/privacy/",
  },
]

const socials = [
  {
    label: "Instagram",
    name: "fa6-brands:instagram",
    link: "https://www.instagram.com/mcmasteru",
  },
  {
    label: "X (formerly Twitter)",
    name: "fa6-brands:x-twitter",
    link: "https://www.twitter.com/mcmasteru",
  },
  {
    label: "Facebook",
    name: "fa6-brands:facebook-f",
    link: "https://www.facebook.com/mcmasteruniversity",
  },
  {
    label: "YouTube",
    name: "fa6-brands:youtube",
    link: "https://www.youtube.com/mcmasterutv",
  },
  {
    label: "LinkedIn",
    name: "fa6-brands:linkedin-in",
    link: "https://www.linkedin.com/school/164897/",
  },
]
---

<footer
  class="bg-maroon flex flex-col items-center p-4 text-white sm:p-6 lg:p-8"
  aria-label="McMaster University footer"
>
  <div class="w-full max-w-100" role="img" aria-label="McMaster University">
    <McMasterFooterLogo aria-hidden="true" />
  </div>
  <nav
    aria-label="Legal links"
    class="font-sans-condensed mt-6 mb-4 flex w-full flex-col items-center justify-center gap-x-24 gap-y-4 border-y border-gray-600 py-5 font-semibold tracking-wider md:flex-row"
  >
    {
      links.map((link) => (
        <a
          href={link.link}
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:no-underline"
        >
          {link.title}
        </a>
      ))
    }
  </nav>
  <nav
    aria-label="McMaster social media"
    class="flex flex-wrap justify-center gap-4 py-4 sm:gap-8 md:gap-11"
  >
    {
      socials.map((social) => (
        <a
          href={social.link}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={`${social.label} (opens in new tab)`}
          class="hover:border-gold hover:text-gold inline-flex rounded-full border-2 p-1.25 transition-colors duration-250"
        >
          <Icon name={social.name} size={18} aria-hidden="true" />
        </a>
      ))
    }
  </nav>
  <nav
    aria-label="McMaster contact details"
    class="flex flex-wrap items-center justify-center gap-4 py-4 text-center sm:gap-6"
  >
    <a
      href="https://www.google.ca/maps/place/?q=place_id:ChIJwSr3RKyELIgRHAFDYeoAnjk"
      target="
      _blank"
      rel="noopener noreferrer"
      class="font-sans-condensed text-sm font-semibold tracking-wider underline hover:no-underline"
    >
      1280 Main Street West &nbsp;
      Hamilton,&nbsp;Ontario&nbsp;&nbsp;L8S&nbsp;4L8
    </a>
    <a
      href="tel:+19055259140"
      class="font-sans-condensed text-sm font-semibold tracking-wider underline hover:no-underline"
    >
      (905) 525-9140
    </a>
  </nav>
  <a
    href="https://www.mcmaster.ca/"
    target="_blank"
    rel="noopener noreferrer"
    class="font-sans-condensed my-4 text-[13px] tracking-wider underline hover:no-underline"
  >
    &copy; {new Date().getFullYear()} McMaster University.
  </a>
</footer>
