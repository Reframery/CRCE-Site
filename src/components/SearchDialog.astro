---
import { Icon } from "astro-icon/components"
---

<dialog
  id="search-dialog"
  aria-labelledby="search-dialog-title"
  class="pagefind-dialog m-auto w-full max-w-2xl bg-[#c6cbce] shadow-lg md:rounded-lg"
>
  <div class="relative mx-auto max-w-2xl p-4">
    <h2 id="search-dialog-title" class="mb-2 text-2xl font-semibold">Search</h2>
    <button
      type="button"
      aria-label="Close search dialog"
      class="pagefind-dialog-close absolute top-3 right-3 text-gray-600 transition-colors hover:cursor-pointer hover:text-gray-900"
    >
      <Icon name="lucide:x" size={24} aria-hidden="true" />
    </button>
    <div id="search"></div>
    <script>
      window.addEventListener("DOMContentLoaded", () => {
        // @ts-ignore
        new PagefindUI({
          element: "#search",
          showSubResults: true,
          showImages: false,
        })

        const searchDialog = document.getElementById(
          "search-dialog"
        ) as HTMLDialogElement | null

        const searchInput = document.querySelector(
          ".pagefind-ui__search-input"
        ) as HTMLInputElement | null

        const searchButton = document.getElementById(
          "search-button"
        ) as HTMLButtonElement | null

        const searchCloseButtons = document.querySelectorAll(
          ".pagefind-dialog-close"
        ) as NodeListOf<HTMLButtonElement>

        if (searchDialog) {
          const openDialog = () => {
            searchDialog.showModal()
            if (searchInput) searchInput.focus()
            document.body.style.overflow = "hidden"
          }

          const closeDialog = () => searchDialog.close()

          // Restore overflow whenever dialog closes (covers Escape, backdrop, button)
          searchDialog.addEventListener("close", () => {
            document.body.style.overflow = ""
          })

          if (searchButton) searchButton.addEventListener("click", openDialog)

          // Backdrop click
          searchDialog.addEventListener("click", (e) => {
            if (e.currentTarget === e.target) closeDialog()
          })

          searchCloseButtons.forEach((button) => {
            button.addEventListener("click", closeDialog)
          })
        }
      })
    </script>
  </div>
  <style>
    #search-dialog::backdrop {
      background-color: rgba(0, 0, 0, 0.5);
      backdrop-filter: blur(2px);
    }
  </style>
</dialog>
